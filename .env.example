# Groq API Key (Gratis) — dapatkan di: https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LangSmith Tracing & Monitoring (Gratis) — dapatkan di: https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
